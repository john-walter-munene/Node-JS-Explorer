<!DOCTYPE html>
<html>
  <head>
    <title><%= title %></title>
    <link rel="stylesheet" href="/styles.css">
  </head>
<body>
  <h1><%= title %></h1>
  <%- include("partials/errors.ejs") %>
  <form action="/<%= user.id %>/update" method="POST">
    <label for="firstName">First Name: </label>
    <input type="text" name="firstName" value="<%= user.firstName %>" required id="firstName">

    <label for="lastName">Last Name: </label>
    <input type="text" name="lastName" value="<%= user.lastName %>" id="lastName" required>

    <label for="email">Email</label>
    <input type="email" name="email" value="<%= user.email %>" id="email" required >

    <label for="age">Age</label>
    <input type="number" name="age" id="age" value="<%= user.age %>"  >

    <label for="bio">Bio</label>
    <input type="text" name="bio" id="bio" value="<%= user.bio %>">

    <button type="submit">Update User</button>
  </form>
  <a href="/">Back to home</a>
</body>
</html>